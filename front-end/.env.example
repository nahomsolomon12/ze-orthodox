# Supabase project URL (found in Supabase dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key — safe to expose in the browser
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: URL of your deployed Express backend (only needed if you route API calls through it)
# VITE_API_URL=https://your-backend.onrender.com
